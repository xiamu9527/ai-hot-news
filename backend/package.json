{
  "name": "ai-hot-news-backend",
  "version": "1.0.0",
  "description": "AI热点新闻监控系统 - 后端服务",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test:ai": "tsx src/scripts/testAiConnection.ts",
    "fix:legacy-verification": "tsx src/scripts/fixLegacyVerificationState.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@the-convocation/twitter-scraper": "^0.22.3",
    "axios": "^1.6.0",
    "better-sqlite3": "^9.0.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "node-schedule": "^2.1.1",
    "openai": "^4.24.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.20",
    "@types/node": "^20.0.0",
    "@types/node-schedule": "^2.1.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
